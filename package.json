{
  "name": "@openclaw/buz",
  "version": "1.0.0",
  "description": "OpenClaw Buz channel plugin via gRPC bidirectional stream",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./api": "./api.ts",
    "./runtime-api": "./runtime-api.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "zod": "^3.22.0"
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "buz",
      "label": "Buz",
      "selectionLabel": "Buz IM (gRPC)",
      "detailLabel": "Buz IM",
      "docsPath": "/channels/buz",
      "docsLabel": "buz",
      "blurb": "Connects OpenClaw to Buz IM via gRPC bidirectional stream.",
      "order": 85
    },
    "install": {
      "npmSpec": "@openclaw/buz",
      "localPath": "extensions/buz_openclaw_channel"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    }
  }
}
